# Copy this file to .Renviron and replace each placeholder with an authorized
# local path. Never commit .Renviron or the protected inputs.
HERRING_EBIRD_V2_EBD=<protected-ebd-path>
HERRING_EBIRD_V2_SED=<protected-sed-path>
HERRING_EBIRD_V2_HERRING=<protected-herring-csv-path>
HERRING_EBIRD_V2_SHORELINE=<protected-shoreline-shp-path>
HERRING_EBIRD_V2_SECTIONS=<protected-sections-shp-path>
VERIFY_INPUT_SHA256=false
