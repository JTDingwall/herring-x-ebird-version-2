+analysis_constraints:
+  independent_row: checklist
+  concurrent_links: additive_joint_period_by_zone_counts
+  full_event_taxon_grid_materialization: prohibited
+  stage4a_outputs_and_checkpoints: immutable
+  results_selected_model_changes: prohibited
+  gadwall_shoveler_main_figure: prohibited
+execution_prerequisites:
+  - committed_versioned_specification_and_code
+  - fixture_and_repository_tests_pass
+  - exact_production_environment_acknowledgement
+  - protected_input_hash_and_cardinality_gates_pass
+final_gate: PASS_PENDING_HUMAN_POST_STAGE4A_EVENT_STUDY_REVIEW
