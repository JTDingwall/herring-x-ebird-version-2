# Restricted or large data
data/raw/**
data/interim/**
data/derived/**
!data/raw/README.md
!data/interim/.gitkeep
!data/derived/.gitkeep

# Outputs and model objects
outputs/**
!outputs/.gitkeep
_targets/
renv/cache/
renv/root/
renv/library/
.Rhistory
.RData
.Ruserdata
.ci-library/
*.rds
*.RDS
*.qs
*.parquet
*.arrow
*.duckdb
*.gpkg
*.csv.gz
*.tsv.gz
*.txt.gz
*.html
*.log
*.stan.csv

# Local secrets and machine-specific configuration
.Renviron
.env
config/local.yml

# IDE and OS
.Rproj.user/
.vscode/
.idea/
.DS_Store
Thumbs.db
~$*.docx

# Explicitly restricted eBird fields or likely extracts
*sampling_event_identifier*
*observer_id*
*locality_id*
*exact_coordinate*
*checklist_sample*

# Audited, synthetic-only reader reports and aggregate setup evidence
!reports/*.html
!docs/*.html
!manuscript/rendered/
!manuscript/rendered/*.html
!outputs/setup/
!outputs/setup/privacy_scan_summary.json
!outputs/stage2_design_lock/
!outputs/stage2_design_lock/*.csv
!outputs/stage2_design_lock/*.json
!outputs/stage3_phase1/
!outputs/stage3_phase1/*.csv
!outputs/stage3_phase1/*.json
!outputs/stage3_phase1_repair/
!outputs/stage3_phase1_repair/*.csv
!outputs/stage3_phase1_repair/*.json
!outputs/stage3_phase1_repair/*.sha256
!outputs/stage3_phase2_sampling_support/
!outputs/stage3_phase2_sampling_support/*.csv
!outputs/stage3_phase2_sampling_support/*.json
!outputs/stage3_phase2_sampling_support/*.sha256
!outputs/stage3_phase3_validation/
!outputs/stage3_phase3_validation/*.csv
!outputs/stage3_phase3_validation/*.json
!outputs/stage3_phase3_validation/*.sha256
!outputs/stage4a_results/
!outputs/stage4a_results/*.csv
!outputs/stage4a_results/*.yml
!outputs/stage4a_results/*.sha256
!outputs/stage4a_results/*.svg
!outputs/stage4a_results/*.html
!outputs/stage4a_publication_sensitivity_v2/
!outputs/stage4a_publication_sensitivity_v2/*.csv
!outputs/stage4a_publication_sensitivity_v2/*.yml
!outputs/stage4a_publication_v2/
!outputs/stage4a_publication_v2/*.csv
!outputs/stage2_design_lock/*.sha256
!outputs/post_stage4a_sog_event_study_v1/
!outputs/post_stage4a_sog_event_study_v1/*.csv
!outputs/post_stage4a_sog_event_study_v1/*.yml
# Refit of the event study carrying the archived primary contrast. Written to
# a new version so the hash-locked v1 release above is never overwritten.
!outputs/post_stage4a_sog_event_study_v1_1/
!outputs/post_stage4a_sog_event_study_v1_1/*.csv
!outputs/post_stage4a_sog_event_study_v1_1/*.yml
# Labelled Laplace (nAGQ = 1) reporting sensitivity, not the primary path.
!outputs/post_stage4a_sog_event_study_laplace_v1/
!outputs/post_stage4a_sog_event_study_laplace_v1/*.csv
!outputs/post_stage4a_sog_event_study_laplace_v1/*.yml
# Pre-onset summary derived from the frozen release; no refitting.
!outputs/post_stage4a_sog_event_study_pretrend_v1/
!outputs/post_stage4a_sog_event_study_pretrend_v1/*.csv
!outputs/post_stage4a_sog_event_study_pretrend_v1/*.yml
# Per-component fixed effects and covariance matrices. These are aggregate
# model summaries, strictly less disclosive than the effect estimates already
# released, and they let any future contrast be evaluated without a refit.
# Allowlisted so the artefacts can be archived; committing them stays a
# deliberate act.
!outputs/post_stage4a_sog_event_study_model_summaries_v1/
!outputs/post_stage4a_sog_event_study_model_summaries_v1/*.rds
!outputs/post_stage4a_sog_event_study_laplace_model_summaries_v1/
!outputs/post_stage4a_sog_event_study_laplace_model_summaries_v1/*.rds

# Local raw-input audit products may contain machine paths
outputs/input_audit_local/**

# Local manuscript render QA intermediates
manuscript/journal_submission/marine_environmental_research/rendered_v6_html/**
manuscript/journal_submission/marine_environmental_research/rendered_v7_html/**
manuscript/journal_submission/marine_environmental_research/audits/pdf_page_renders_v6/**
manuscript/journal_submission/marine_environmental_research/audits/docx_visual_conversion_v6/**
